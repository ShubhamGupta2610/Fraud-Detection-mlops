# Copy this file to .env and fill in real values locally.
# NEVER commit the actual .env file - it is listed in .gitignore.

# Local docker-compose Postgres (default works out of the box with docker-compose.yml)
DATABASE_URL=postgresql://fraud_user:fraud_pass@localhost:5432/fraud_engine

# When ready to point at real Supabase instead of local Postgres,
# replace the value above with your Supabase connection string here -
# never paste it directly into config.py or any other source file.

ENVIRONMENT=development
LOG_LEVEL=INFO
